# =============================================================================
# NextCommerce — Environment Variables Template
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Client SDK  (NEXT_PUBLIC = exposed to browser, required by client SDK)
# Firebase Console → Project Settings → General → Your apps → Web app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# -----------------------------------------------------------------------------
# Cloudinary  (NEXT_PUBLIC = exposed to browser, required for direct client upload)
# Cloudinary Dashboard → Settings → Upload → Upload presets
# ⚠  Restrict the upload preset to specific folders in Cloudinary dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# -----------------------------------------------------------------------------
# Firebase Admin SDK  (server-side ONLY — never add NEXT_PUBLIC_ prefix)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# ⚠  Keep these secret — never expose to the browser or commit to git
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
